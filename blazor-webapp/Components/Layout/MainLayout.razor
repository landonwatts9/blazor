@inherits LayoutComponentBase
@inject AccessService Access

<div class="sam-app">
    <header class="sam-header">
        <div class="sam-header-left">
            <img src="sam-logo.png" alt="Sun American Mortgage" class="sam-logo"
                 onerror="this.style.display='none'" />
            <div class="sam-title-block">
                <h1>SAM Reporting</h1>
                <div class="sam-subtitle">Sun American Mortgage &mdash; Internal Dashboards</div>
            </div>
        </div>
        <nav class="sam-nav">
            <NavLink href="/" Match="NavLinkMatch.All">Home</NavLink>
            @if (allowed is not null)
            {
                @foreach (var d in DashboardCatalog.All.Where(d => allowed.Contains(d.Key)))
                {
                    <NavLink href="@d.Route">@d.Title</NavLink>
                }
            }
        </nav>
    </header>

    <main class="sam-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private HashSet<string>? allowed;

    protected override async Task OnInitializedAsync()
    {
        var user = await Access.CurrentUsernameAsync();
        allowed = await Access.GetAllowedDashboardsAsync(user);
    }
}
