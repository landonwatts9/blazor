@inherits LayoutComponentBase

<div class="sam-app">
    <header class="sam-header">
        <div class="sam-header-left">
            <h1>SAM Reporting</h1>
            <div class="sam-subtitle">Sun American Mortgage &mdash; Internal Dashboards</div>
        </div>
        <nav class="sam-nav">
            <NavLink href="/" Match="NavLinkMatch.All">Home</NavLink>
            <NavLink href="/historical">Historical</NavLink>
            <NavLink href="/processor">Processor Pipeline</NavLink>
        </nav>
    </header>

    <main class="sam-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
