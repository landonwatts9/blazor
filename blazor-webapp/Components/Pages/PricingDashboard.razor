@page "/pricing"
@rendermode InteractiveServer
@using SamReporting.Models
@using SamReporting.Services
@using ApexCharts
@inject PricingService Svc
@inject AccessService Access

<PageTitle>Pricing Dashboard</PageTitle>

@if (accessChecked && !authorized)
{
    <NoAccessMessage />
}
else
{
    <div class="period-bar">
        <div class="period-group">
            <label>START</label>
            <InputDate @bind-Value="startDate" />
        </div>
        <div class="period-group">
            <label>END</label>
            <InputDate @bind-Value="endDate" />
        </div>
        <div class="period-group">
            <label>CAPTURED</label>
            <select @bind="captureFilter">
                <option value="">All</option>
                <option value="Yes">Captured</option>
                <option value="No">Not Captured</option>
            </select>
        </div>
        <div class="period-group">
            <label>LOAN OFFICERS</label>
            <LoMultiSelect Options="loOptions" @bind-SelectedIds="selectedLoIds" />
        </div>
        <button class="btn-apply" @onclick="Apply" disabled="@loading">
            @(loading ? "Loading..." : "Apply")
        </button>
    </div>

    @if (kpis is null)
    {
        <p class="empty">@(loading ? "Loading..." : "Click Apply to load.")</p>
    }
    else
    {
        <div class="kpi-row primary">
            <KpiCard Label="LOCKS"             Value="@kpis.Locks.ToString("N0")"                                Accent="blue" />
            <KpiCard Label="VOLUME LOCKED"     Value="@FmtMoneyShort(kpis.Volume)"                               Accent="teal" />
            <KpiCard Label="AVG MARGIN (BPS)"  Value="@kpis.AvgMarginBps.ToString("F1")"  SubLabel="sell − buy"  Accent="amber" />
            <KpiCard Label="AVG RATE"          Value="@($"{kpis.AvgRate:F3}%")"                                  Accent="slate" />
            <KpiCard Label="AVG CONCESSIONS"   Value="@FmtMoney(kpis.AvgConcessions)" SubLabel="per loan"        Accent="red" />
            <KpiCard Label="CAPTURE RATE"      Value="@($"{kpis.CaptureRatePct:F1}%")" SubLabel="of yes/no loans" Accent="green" />
        </div>

        <div class="tabs">
            <button class="tab @(tab == "detail" ? "active" : "")"  @onclick='() => SelectTab("detail")'>Loan Detail</button>
            <button class="tab @(tab == "lo" ? "active" : "")"      @onclick='() => SelectTab("lo")'>LO Summary</button>
            <button class="tab @(tab == "trend" ? "active" : "")"   @onclick='() => SelectTab("trend")'>Historical Trend</button>
            <button class="tab @(tab == "vs" ? "active" : "")"      @onclick='() => SelectTab("vs")'>LO vs Company</button>
            <button class="tab @(tab == "conc" ? "active" : "")"    @onclick='() => SelectTab("conc")'>Concession Analysis</button>
        </div>

        @if (tab == "detail")
        {
            @if (loans is null) { <p class="empty">Loading...</p> }
            else if (loans.Count == 0) { <p class="empty">No loans match the current filter.</p> }
            else
            {
                <div class="card">
                    <h3>Loan Detail <span class="muted">@loans.Count loans</span></h3>
                    <table class="data-table">
                        <thead>
                            <tr>
                                @SortHeader("LoanNumber",    "Loan #",      detailSort, detailDesc, SortDetail, numeric: true)
                                @SortHeader("BorrowerName",  "Borrower",    detailSort, detailDesc, SortDetail)
                                @SortHeader("LockDate",      "Lock Date",   detailSort, detailDesc, SortDetail)
                                @SortHeader("LoName",        "LO",          detailSort, detailDesc, SortDetail)
                                @SortHeader("Channel",       "Channel",     detailSort, detailDesc, SortDetail)
                                @SortHeader("CommitmentType","Commit",      detailSort, detailDesc, SortDetail)
                                @SortHeader("WholeLoan",     "Whole Loan",  detailSort, detailDesc, SortDetail)
                                @SortHeader("Captured",      "Captured",    detailSort, detailDesc, SortDetail)
                                @SortHeader("InterestRate",  "Rate",        detailSort, detailDesc, SortDetail, numeric: true)
                                @SortHeader("BuyPrice",      "Buy",         detailSort, detailDesc, SortDetail, numeric: true)
                                @SortHeader("SellPrice",     "Sell",        detailSort, detailDesc, SortDetail, numeric: true)
                                @SortHeader("MarginBps",     "Margin (bps)",detailSort, detailDesc, SortDetail, numeric: true)
                                @SortHeader("Concessions",   "Concessions", detailSort, detailDesc, SortDetail, numeric: true)
                                @SortHeader("LoanAmount",    "Amount",      detailSort, detailDesc, SortDetail, numeric: true)
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in SortedLoans)
                            {
                                <tr>
                                    <td class="num">@r.LoanNumber</td>
                                    <td>@r.BorrowerName</td>
                                    <td>@FmtDate(r.LockDate)</td>
                                    <td>@r.LoName</td>
                                    <td>@r.Channel</td>
                                    <td>@r.CommitmentType</td>
                                    <td>@(r.WholeLoan ? "✓" : "")</td>
                                    <td>@CapturedGlyph(r.Captured)</td>
                                    <td class="num">@(r.InterestRate?.ToString("F3") ?? "")</td>
                                    <td class="num">@(r.BuyPrice?.ToString("F3") ?? "")</td>
                                    <td class="num">@(r.SellPrice?.ToString("F3") ?? "")</td>
                                    <td class="num">@(r.MarginBps?.ToString("F1") ?? "")</td>
                                    <td class="num">@FmtMoneyOrBlank(r.Concessions)</td>
                                    <td class="num">@FmtMoneyOrBlank(r.LoanAmount)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else if (tab == "lo")
        {
            @if (loSummary is null) { <p class="empty">Loading...</p> }
            else if (loSummary.Count == 0) { <p class="empty">No LO data for this period.</p> }
            else
            {
                <div class="card">
                    <h3>LO Summary <span class="muted">@loSummary.Count LOs · sorted by margin</span></h3>
                    <table class="data-table">
                        <thead>
                            <tr>
                                @SortHeader("LoName",          "LO",                 loSort, loDesc, SortLo)
                                @SortHeader("Units",           "Units",              loSort, loDesc, SortLo, numeric: true)
                                @SortHeader("Volume",          "Volume",             loSort, loDesc, SortLo, numeric: true)
                                @SortHeader("AvgRate",         "Avg Rate",           loSort, loDesc, SortLo, numeric: true)
                                @SortHeader("AvgMarginBps",    "Avg Margin (bps)",   loSort, loDesc, SortLo, numeric: true)
                                @SortHeader("AvgConcessions",  "Avg Concessions",    loSort, loDesc, SortLo, numeric: true)
                                @SortHeader("CaptureRatePct",  "Capture %",          loSort, loDesc, SortLo, numeric: true)
                                @SortHeader("CapturedUnits",   "Captured",           loSort, loDesc, SortLo, numeric: true)
                                @SortHeader("NonCapturedUnits","Not Captured",       loSort, loDesc, SortLo, numeric: true)
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in SortedLoSummary)
                            {
                                <tr>
                                    <td>@r.LoName</td>
                                    <td class="num">@r.Units</td>
                                    <td class="num">@FmtMoney(r.Volume)</td>
                                    <td class="num">@(r.AvgRate?.ToString("F3") ?? "") %</td>
                                    <td class="num">@(r.AvgMarginBps?.ToString("F1") ?? "")</td>
                                    <td class="num">@FmtMoney(r.AvgConcessions)</td>
                                    <td class="num">@r.CaptureRatePct.ToString("F1") %</td>
                                    <td class="num">@r.CapturedUnits</td>
                                    <td class="num">@r.NonCapturedUnits</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else if (tab == "trend")
        {
            @if (trend is null) { <p class="empty">Loading...</p> }
            else
            {
                <div class="card">
                    <h3>Historical Trend <span class="muted">trailing 12 months</span>
                        <span class="metric-toggle">
                            <label>Metric:</label>
                            <select @bind="trendMetric">
                                <option value="margin">Avg Margin (bps)</option>
                                <option value="rate">Avg Rate</option>
                                <option value="volume">Volume Locked</option>
                            </select>
                        </span>
                    </h3>
                    @if (TrendSeries.Count == 0)
                    {
                        <p class="empty">No trend data for the selected period / LOs.</p>
                    }
                    else
                    {
                        <ApexChart TItem="PricingTrendPoint" Options="_trendOptions" Height="380">
                            @foreach (var (loName, points) in TrendSeries)
                            {
                                <ApexPointSeries TItem="PricingTrendPoint" Items="points" Name="@loName"
                                                 SeriesType="SeriesType.Line"
                                                 XValue="@(p => p.Month)"
                                                 YValue="@(p => TrendY(p))" />
                            }
                        </ApexChart>
                    }
                </div>
            }
        }
        else if (tab == "vs")
        {
            @if (loSummary is null) { <p class="empty">Loading...</p> }
            else if (loSummary.Count == 0) { <p class="empty">No LO data for this period.</p> }
            else
            {
                <div class="card">
                    <h3>LO vs Company Average
                        <span class="metric-toggle">
                            <label>Metric:</label>
                            <select @bind="vsMetric">
                                <option value="margin">Avg Margin (bps)</option>
                                <option value="rate">Avg Rate</option>
                                <option value="concessions">Avg Concessions</option>
                            </select>
                        </span>
                    </h3>
                    <ApexChart TItem="VsRow" Options="_vsOptions" Height="380">
                        <ApexPointSeries TItem="VsRow" Items="VsRows" Name="@VsMetricLabel"
                                         SeriesType="SeriesType.Bar"
                                         XValue="@(e => e.LoName)"
                                         YValue="@(e => (decimal)(e.Value ?? 0))" />
                    </ApexChart>
                    <p class="muted">Reference line: company avg = @CompanyAvgLabel</p>
                </div>
            }
        }
        else if (tab == "conc")
        {
            @if (loSummary is null) { <p class="empty">Loading...</p> }
            else if (loSummary.Count == 0) { <p class="empty">No LO data for this period.</p> }
            else
            {
                <div class="card">
                    <h3>Concession Analysis <span class="muted">avg concessions per loan</span></h3>
                    <ApexChart TItem="LoPricingSummary" Options="_concOptions" Height="380">
                        <ApexPointSeries TItem="LoPricingSummary" Items="ConcessionRanked" Name="Avg Concessions"
                                         SeriesType="SeriesType.Bar"
                                         XValue="@(e => e.LoName)"
                                         YValue="@(e => e.AvgConcessions)" />
                    </ApexChart>
                    <table class="data-table">
                        <thead>
                            <tr><th>Rank</th><th>LO</th><th class="num">Units</th><th class="num">Avg Concessions</th><th class="num">Total Concessions (est)</th></tr>
                        </thead>
                        <tbody>
                            @{ var rank = 1; }
                            @foreach (var r in ConcessionRanked)
                            {
                                <tr>
                                    <td>@rank</td>
                                    <td>@r.LoName</td>
                                    <td class="num">@r.Units</td>
                                    <td class="num">@FmtMoney(r.AvgConcessions)</td>
                                    <td class="num">@FmtMoney(r.AvgConcessions * r.Units)</td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    }
}

@code {
    private bool accessChecked;
    private bool authorized;
    private bool loading;
    private string tab = "detail";

    private DateTime startDate = new(DateTime.Today.Year, 1, 1);
    private DateTime endDate = DateTime.Today.AddDays(1);
    private string captureFilter = "";
    private List<int> selectedLoIds = new();

    private IReadOnlyList<LoOption> loOptions = Array.Empty<LoOption>();

    private PricingKpis? kpis;
    private IReadOnlyList<PricingLoanRow>? loans;
    private IReadOnlyList<LoPricingSummary>? loSummary;
    private IReadOnlyList<PricingTrendPoint>? trend;

    private string detailSort = "LockDate";  private bool detailDesc = true;
    private string loSort = "AvgMarginBps";  private bool loDesc = true;

    private string trendMetric = "margin";
    private string vsMetric = "margin";

    private readonly ApexChartOptions<PricingTrendPoint> _trendOptions = new()
    {
        Chart = new Chart { Toolbar = new Toolbar { Show = false } },
        Stroke = new Stroke { Curve = Curve.Smooth, Width = 3 },
        Markers = new Markers { Size = 4 },
        Legend = new Legend { Position = LegendPosition.Top },
    };

    private readonly ApexChartOptions<VsRow> _vsOptions = new()
    {
        Chart = new Chart { Toolbar = new Toolbar { Show = false } },
        Colors = new List<string> { "#0B426A" },
        DataLabels = new DataLabels { Enabled = true },
    };

    private readonly ApexChartOptions<LoPricingSummary> _concOptions = new()
    {
        Chart = new Chart { Toolbar = new Toolbar { Show = false } },
        Colors = new List<string> { "#dc2626" },
        DataLabels = new DataLabels { Enabled = true },
    };

    public record VsRow(string LoName, double? Value);

    protected override async Task OnInitializedAsync()
    {
        var user = await Access.CurrentUsernameAsync();
        authorized = await Access.CanAccessAsync(user, "pricing");
        accessChecked = true;
        if (!authorized) return;

        loOptions = await Svc.GetLoOptionsAsync();
        await Apply();
    }

    private async Task Apply()
    {
        kpis = null;
        loans = null;
        loSummary = null;
        trend = null;
        loading = true;
        try
        {
            kpis = await Svc.GetKpisAsync(BuildFilter());
            await EnsureTabLoaded(tab);
        }
        finally
        {
            loading = false;
        }
    }

    private PricingFilter BuildFilter() => new(
        Start: startDate,
        End: endDate,
        NmlsIds: selectedLoIds.Count == 0 ? null : selectedLoIds,
        CaptureFilter: string.IsNullOrEmpty(captureFilter) ? null : captureFilter);

    private async Task SelectTab(string next)
    {
        tab = next;
        await EnsureTabLoaded(next);
    }

    private async Task EnsureTabLoaded(string which)
    {
        var f = BuildFilter();
        switch (which)
        {
            case "detail" when loans is null:     loans = await Svc.GetLoanDetailAsync(f); break;
            case "lo"     when loSummary is null: loSummary = await Svc.GetLoSummaryAsync(f); break;
            case "trend"  when trend is null:     trend = await Svc.GetTrendAsync(f); break;
            case "vs"     when loSummary is null: loSummary = await Svc.GetLoSummaryAsync(f); break;
            case "conc"   when loSummary is null: loSummary = await Svc.GetLoSummaryAsync(f); break;
        }
    }

    // ─── Sort helpers ────────────────────────────────────────────────────────

    private static readonly Dictionary<string, Func<PricingLoanRow, object?>> DetailKeys = new()
    {
        ["LoanNumber"]     = x => x.LoanNumber,
        ["BorrowerName"]   = x => x.BorrowerName,
        ["LockDate"]       = x => x.LockDate,
        ["LoName"]         = x => x.LoName,
        ["Channel"]        = x => x.Channel,
        ["CommitmentType"] = x => x.CommitmentType,
        ["WholeLoan"]      = x => x.WholeLoan,
        ["Captured"]       = x => x.Captured,
        ["InterestRate"]   = x => x.InterestRate,
        ["BuyPrice"]       = x => x.BuyPrice,
        ["SellPrice"]      = x => x.SellPrice,
        ["MarginBps"]      = x => x.MarginBps,
        ["Concessions"]    = x => x.Concessions,
        ["LoanAmount"]     = x => x.LoanAmount,
    };

    private static readonly Dictionary<string, Func<LoPricingSummary, object?>> LoKeys = new()
    {
        ["LoName"]           = x => x.LoName,
        ["Units"]            = x => x.Units,
        ["Volume"]           = x => x.Volume,
        ["AvgRate"]          = x => x.AvgRate,
        ["AvgMarginBps"]     = x => x.AvgMarginBps,
        ["AvgConcessions"]   = x => x.AvgConcessions,
        ["CaptureRatePct"]   = x => x.CaptureRatePct,
        ["CapturedUnits"]    = x => x.CapturedUnits,
        ["NonCapturedUnits"] = x => x.NonCapturedUnits,
    };

    private void SortDetail(string col) => ToggleSort(col, ref detailSort, ref detailDesc);
    private void SortLo(string col)     => ToggleSort(col, ref loSort, ref loDesc);

    private static void ToggleSort(string col, ref string current, ref bool desc)
    {
        if (current == col) desc = !desc;
        else { current = col; desc = true; }
    }

    private IEnumerable<PricingLoanRow> SortedLoans
        => loans is null ? Enumerable.Empty<PricingLoanRow>() : ApplySort(loans, detailSort, detailDesc, DetailKeys);
    private IEnumerable<LoPricingSummary> SortedLoSummary
        => loSummary is null ? Enumerable.Empty<LoPricingSummary>() : ApplySort(loSummary, loSort, loDesc, LoKeys);

    private static IEnumerable<T> ApplySort<T>(IEnumerable<T> src, string col, bool desc,
        Dictionary<string, Func<T, object?>> keys)
    {
        var key = keys.GetValueOrDefault(col) ?? keys.Values.First();
        return desc ? src.OrderByDescending(key, NullFirstComparer.Instance)
                    : src.OrderBy(key, NullFirstComparer.Instance);
    }

    private sealed class NullFirstComparer : IComparer<object?>
    {
        public static readonly NullFirstComparer Instance = new();
        public int Compare(object? x, object? y) => (x, y) switch
        {
            (null, null) => 0,
            (null, _)    => -1,
            (_, null)    => 1,
            _            => Comparer<object>.Default.Compare(x, y)
        };
    }

    private RenderFragment SortHeader(string col, string label, string current, bool desc,
        Action<string> onClick, bool numeric = false) => builder =>
    {
        var classes = "sortable" + (numeric ? " num" : "") + (current == col ? " sort-active" : "");
        var arrow = current == col ? (desc ? "▼" : "▲") : "↕";
        builder.OpenElement(0, "th");
        builder.AddAttribute(1, "class", classes);
        builder.AddAttribute(2, "onclick", EventCallback.Factory.Create(this, () => onClick(col)));
        builder.AddContent(3, label);
        builder.OpenElement(4, "span");
        builder.AddAttribute(5, "class", "sort-indicator");
        builder.AddContent(6, arrow);
        builder.CloseElement();
        builder.CloseElement();
    };

    // ─── Trend derived data ──────────────────────────────────────────────────

    private List<(string LoName, List<PricingTrendPoint> Points)> TrendSeries
    {
        get
        {
            if (trend is null || trend.Count == 0) return new();
            // If too many LOs selected, aggregate to one series for readability
            var byLo = trend.GroupBy(t => t.LoName).ToList();
            if (byLo.Count > 8)
            {
                var aggregated = trend
                    .GroupBy(t => t.Month)
                    .OrderBy(g => g.Key)
                    .Select(g => new PricingTrendPoint(
                        Month: g.Key,
                        LoName: "All Selected",
                        Units: g.Sum(p => p.Units),
                        Volume: g.Sum(p => p.Volume),
                        AvgMarginBps: g.Average(p => p.AvgMarginBps ?? 0),
                        AvgRate: g.Average(p => p.AvgRate ?? 0)))
                    .ToList();
                return new() { ("All Selected", aggregated) };
            }
            return byLo
                .OrderBy(g => g.Key)
                .Select(g => (g.Key, g.OrderBy(p => p.Month).ToList()))
                .ToList();
        }
    }

    private decimal TrendY(PricingTrendPoint p) => trendMetric switch
    {
        "rate"   => (decimal)(p.AvgRate ?? 0),
        "volume" => p.Volume,
        _        => (decimal)(p.AvgMarginBps ?? 0),
    };

    // ─── LO vs Company derived data ──────────────────────────────────────────

    private IEnumerable<VsRow> VsRows
    {
        get
        {
            if (loSummary is null) return Enumerable.Empty<VsRow>();
            return loSummary.Select(s => new VsRow(s.LoName, VsValue(s)));
        }
    }

    private double? VsValue(LoPricingSummary s) => vsMetric switch
    {
        "rate"        => s.AvgRate,
        "concessions" => (double?)s.AvgConcessions,
        _             => s.AvgMarginBps,
    };

    private string VsMetricLabel => vsMetric switch
    {
        "rate" => "Avg Rate (%)",
        "concessions" => "Avg Concessions ($)",
        _ => "Avg Margin (bps)",
    };

    private string CompanyAvgLabel
    {
        get
        {
            if (kpis is null) return "—";
            return vsMetric switch
            {
                "rate"        => $"{kpis.AvgRate:F3}%",
                "concessions" => FmtMoney(kpis.AvgConcessions),
                _             => $"{kpis.AvgMarginBps:F1} bps",
            };
        }
    }

    // ─── Concession analysis ─────────────────────────────────────────────────

    private IEnumerable<LoPricingSummary> ConcessionRanked =>
        loSummary is null
            ? Enumerable.Empty<LoPricingSummary>()
            : loSummary.OrderByDescending(s => s.AvgConcessions);

    // ─── Formatting ──────────────────────────────────────────────────────────

    private static string FmtDate(DateTime? d) => d?.ToString("yyyy-MM-dd") ?? "";
    private static string FmtMoney(decimal v) => $"${v:N0}";
    private static string FmtMoneyOrBlank(decimal? v) => v is null || v == 0m ? "" : $"${v:N0}";
    private static string FmtMoneyShort(decimal v) =>
        Math.Abs(v) >= 1_000_000m ? $"${v / 1_000_000m:F1}M"
        : Math.Abs(v) >= 1_000m   ? $"${v / 1_000m:F0}K"
        : $"${v:N0}";

    private static string CapturedGlyph(string? captured) => captured switch
    {
        "Yes" => "✓",
        "No"  => "✗",
        _     => "—",
    };
}
